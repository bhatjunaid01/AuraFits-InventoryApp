{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura Fits",
  "version": "1.0.13",
  "identifier": "com.aurafits.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aura Fits",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Aura Fits",
    "category": "Business",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Inventory, POS, expenses, and dashboard for Aura Fits",
    "longDescription": "Aura Fits Management Console built with Tauri, React, Vite, and SQLite.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/bhatjunaid01/AuraFits-InventoryApp/releases/latest/download/latest.json"
      ]
    }
  }
}